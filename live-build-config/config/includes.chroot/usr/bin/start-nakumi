#!/bin/bash
# start-nakumi - Wayland session launcher for NakumiOS
# Launched by greetd as the default session command.

set -e

# === Core Wayland Environment ===
export XDG_SESSION_TYPE=wayland
export XDG_CURRENT_DESKTOP=NakumiOS
export XDG_SESSION_DESKTOP=NakumiOS
export QT_QPA_PLATFORM=wayland
export QT_WAYLAND_DISABLE_WINDOWDECORATION=1
export MOZ_ENABLE_WAYLAND=1

# === XDG Runtime Directory ===
if [ -z "$XDG_RUNTIME_DIR" ]; then
    export XDG_RUNTIME_DIR="/run/user/$(id -u)"
    if [ ! -d "$XDG_RUNTIME_DIR" ]; then
        mkdir -p "$XDG_RUNTIME_DIR"
        chmod 0700 "$XDG_RUNTIME_DIR"
    fi
fi

# === Logging helper ===
log() {
    echo "$1"
    echo "$(date '+%Y-%m-%d %H:%M:%S') $1" >> /tmp/nakumi-session.log
}

# === VM Resilience: Software Rendering Fallback ===
# Detect if we are in a VM or if GPU/DRM is unavailable.
detect_vm() {
    if [ -f /sys/class/dmi/id/product_name ]; then
        product=$(cat /sys/class/dmi/id/product_name 2>/dev/null || echo "")
        case "$product" in
            *VirtualBox*|*VMware*|*QEMU*|*KVM*|*Bochs*)
                return 0
                ;;
        esac
    fi
    if command -v systemd-detect-virt >/dev/null 2>&1; then
        if systemd-detect-virt -q 2>/dev/null; then
            return 0
        fi
    fi
    return 1
}

# Check if hardware rendering is available (DRI render nodes present)
has_gpu_render() {
    if ls /dev/dri/renderD* >/dev/null 2>&1; then
        return 0
    fi
    return 1
}

if detect_vm; then
    log "[NakumiOS] Virtual machine detected."
    # Hardware cursors are unreliable in VMs — always disable
    export WLR_NO_HARDWARE_CURSORS=1

    if has_gpu_render; then
        # VM has GPU acceleration (e.g., VMware 3D, virtio-gpu, VirtualBox 3D).
        # Let wlroots auto-select the best renderer (gles2/vulkan) instead of
        # forcing pixman, which can fail with VM GPU drivers like vmwgfx.
        log "[NakumiOS] GPU render node found — using hardware-accelerated rendering."
    else
        # VM without GPU acceleration — must use software rendering
        log "[NakumiOS] No GPU render node — enabling software rendering (pixman)."
        export WLR_RENDERER=pixman
        export LIBGL_ALWAYS_SOFTWARE=1
    fi
elif ! has_gpu_render; then
    log "[NakumiOS] No GPU detected, enabling software rendering (pixman)."
    export WLR_RENDERER=pixman
    export LIBGL_ALWAYS_SOFTWARE=1
    export WLR_NO_HARDWARE_CURSORS=1
fi

# === D-Bus Session ===
if [ -z "$DBUS_SESSION_BUS_ADDRESS" ]; then
    eval "$(dbus-launch --sh-syntax)"
    export DBUS_SESSION_BUS_ADDRESS
fi

# === PipeWire Audio ===
if command -v pipewire >/dev/null 2>&1; then
    pipewire &
    sleep 0.5
    if command -v wireplumber >/dev/null 2>&1; then
        wireplumber &
    fi
fi

# === Launch the Compositor ===
# The -s flag starts a startup command after the Wayland socket is ready.
# This launches the panel and launcher inside the compositor session.
#
# If the compositor crashes immediately (e.g., GPU driver issue), fall back
# to software rendering and retry once.
log "[NakumiOS] Starting compositor..."
nakumi-wm -s "nakumi-panel & nakumi-launcher" &
WM_PID=$!

# Give the compositor a moment to initialise
sleep 2

if kill -0 "$WM_PID" 2>/dev/null; then
    # Compositor is running — wait for it to exit normally
    log "[NakumiOS] Compositor running (PID $WM_PID)."
    wait "$WM_PID"
else
    # Compositor died during startup — retry with software rendering
    log "[NakumiOS] Compositor crashed, retrying with software rendering (pixman)..."
    export WLR_RENDERER=pixman
    export LIBGL_ALWAYS_SOFTWARE=1
    export WLR_NO_HARDWARE_CURSORS=1
    exec nakumi-wm -s "nakumi-panel & nakumi-launcher"
fi
